# Application
APP_NAME="Auto Garden Workshop System"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:80"]

# Database
DATABASE_URL=postgresql+asyncpg://autogarden:password@localhost:5432/autogarden_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/media
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=
S3_REGION=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@autogarden.com.np

# Business
BUSINESS_NAME="Auto Garden Pvt. Ltd."
BUSINESS_ADDRESS="Bharatpur, Chitwan, Nepal"
BUSINESS_PHONE="+977-56-XXXXXX"
BUSINESS_PAN="XXXXXXXXX"
VAT_RATE=13.0